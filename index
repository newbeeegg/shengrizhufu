            <div class="absolute top-10 left-10 w-4 h-4 rounded-full bg-pink-300 opacity-50"></div>
            <div class="absolute top-20 right-20 w-6 h-6 rounded-full bg-blue-300 opacity-50"></div>
            <div class="absolute bottom-10 left-1/4 w-3 h-3 rounded-full bg-yellow-300 opacity-50"></div>
            <div class="absolute bottom-20 right-1/3 w-5 h-5 rounded-full bg-green-300 opacity-50"></div>
        </div>
    </header>

    <!-- 模板选择区域 -->
    <section id="templates" class="py-16 bg-white">
        <div class="container mx-auto px-4">
            <div class="text-center mb-12">
                <h2 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-dark mb-4">选择模板</h2>
                <p class="text-gray-600 max-w-2xl mx-auto">
                    我们提供多种风格的生日祝福模板，从温馨浪漫到幽默有趣，总有一款适合你！
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- 模板1：豪华风格 -->
                <div class="template-card bg-white rounded-xl shadow-lg overflow-hidden cursor-pointer" data-template="luxury">
                    <div class="relative">
                        <img src="https://p3-flow-imagex-sign.byteimg.com/tos-cn-i-a9rns2rl98/rc/pc/super_tool/96cafd26b1f54379b69cf8ba6242dcc8~tplv-a9rns2rl98-image.image?lk3s=8e244e95&rcl=202603182152091F69194F6EE27C8D2F2D&rrcfp=f06b921b&x-expires=1776433965&x-signature=9iewx3chk1rChyI2U6uqIixbnuk%3D" 
                             alt="豪华风格模板" 
                             class="w-full h-48 object-cover">
                        <div class="absolute top-3 right-3 bg-primary text-white text-xs font-bold px-2 py-1 rounded-full">
                            热门
                        </div>
                    </div>
                    <div class="p-4">
                        <h3 class="font-bold text-lg mb-2">豪华金色</h3>
                        <p class="text-gray-600 text-sm mb-3">优雅的深蓝色背景搭配金色装饰，彰显高贵气质</p>
                        <div class="flex justify-between items-center">
                            <span class="text-xs text-gray-500">适合：正式场合</span>
                            <button class="select-template-btn bg-primary/10 hover:bg-primary/20 text-primary text-sm font-medium py-1 px-3 rounded-full transition-colors">
                                选择
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- 模板2：卡通风格 -->
                <div class="template-card bg-white rounded-xl shadow-lg overflow-hidden cursor-pointer" data-template="cartoon">
                    <div class="relative">
                        <img src="https://p3-flow-imagex-sign.byteimg.com/tos-cn-i-a9rns2rl98/rc/pc/super_tool/e510255bbb19406bb677da39af7a3b1d~tplv-a9rns2rl98-image.image?lk3s=8e244e95&rcl=202603182152091F69194F6EE27C8D2F2D&rrcfp=f06b921b&x-expires=1776433973&x-signature=sPcoV2zdQ7gjBYN04ios0r3jcBs%3D" 
                             alt="卡通风格模板" 
                             class="w-full h-48 object-cover">
                    </div>
                    <div class="p-4">
                        <h3 class="font-bold text-lg mb-2">卡通动物</h3>
                        <p class="text-gray-600 text-sm mb-3">可爱的卡通动物和彩虹元素，充满童趣和活力</p>
                        <div class="flex justify-between items-center">
                            <span class="text-xs text-gray-500">适合：儿童、年轻人</span>
                            <button class="select-template-btn bg-primary/10 hover:bg-primary/20 text-primary text-sm font-medium py-1 px-3 rounded-full transition-colors">
                                选择
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- 模板3：浪漫风格 -->
                <div class="template-card bg-white rounded-xl shadow-lg overflow-hidden cursor-pointer" data-template="romantic">
                    <div class="relative">
                        <img src="https://p3-flow-imagex-sign.byteimg.com/tos-cn-i-a9rns2rl98/rc/pc/super_tool/6ef2f2a20904471498b674e3cf87344a~tplv-a9rns2rl98-image.image?lk3s=8e244e95&rcl=202603182152091F69194F6EE27C8D2F2D&rrcfp=f06b921b&x-expires=1776433966&x-signature=yWgRcUL07DWYUngMJwn%2Fiy0gmYU%3D" 
                             alt="浪漫风格模板" 
                             class="w-full h-48 object-cover">
                    </div>
                    <div class="p-4">
                        <h3 class="font-bold text-lg mb-2">浪漫爱情</h3>
                        <p class="text-gray-600 text-sm mb-3">粉色心形气球背景，表达浓浓的爱意和温馨祝福</p>
                        <div class="flex justify-between items-center">
                            <span class="text-xs text-gray-500">适合：爱人、情侣</span>
                            <button class="select-template-btn bg-primary/10 hover:bg-primary/20 text-primary text-sm font-medium py-1 px-3 rounded-full transition-colors">
                                选择
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- 模板4：简约风格 -->
                <div class="template-card bg-white rounded-xl shadow-lg overflow-hidden cursor-pointer" data-template="minimalist">
                    <div class="relative">
                        <img src="https://p3-flow-imagex-sign.byteimg.com/tos-cn-i-a9rns2rl98/rc/pc/super_tool/bf5ab7457a2048dcadb8231dd58ef33e~tplv-a9rns2rl98-image.image?lk3s=8e244e95&rcl=202603182152091F69194F6EE27C8D2F2D&rrcfp=f06b921b&x-expires=1776433966&x-signature=MphpMB%2B8Vb58r%2FEVFdrHj75HqME%3D" 
                             alt="简约风格模板" 
                             class="w-full h-48 object-cover">
                    </div>
                    <div class="p-4">
                        <h3 class="font-bold text-lg mb-2">简约现代</h3>
                        <p class="text-gray-600 text-sm mb-3">简洁的设计和柔和的色彩，展现现代简约美学</p>
                        <div class="flex justify-between items-center">
                            <span class="text-xs text-gray-500">适合：年轻人、职场人士</span>
                            <button class="select-template-btn bg-primary/10 hover:bg-primary/20 text-primary text-sm font-medium py-1 px-3 rounded-full transition-colors">
                                选择
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 个性化定制区域 -->
    <section id="customize" class="py-16 bg-gradient-to-br from-blue-50 to-purple-50">
        <div class="container mx-auto px-4">
            <div class="text-center mb-12">
                <h2 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-dark mb-4">个性化定制</h2>
                <p class="text-gray-600 max-w-2xl mx-auto">
                    添加照片、编辑文字，让你的生日祝福更加独特和个性化！
                </p>
            </div>
            
            <div class="max-w-4xl mx-auto bg-white rounded-xl shadow-xl p-6 md:p-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <!-- 左侧：表单 -->
                    <div>
                        <h3 class="text-xl font-bold mb-6 text-dark border-b pb-2">编辑信息</h3>
                        
                        <!-- 寿星姓名 -->
                        <div class="mb-4">
                            <label for="name" class="block text-gray-700 font-medium mb-2">寿星姓名</label>
                            <input type="text" id="name" placeholder="请输入寿星姓名" 
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors">
                        </div>
                        
                        <!-- 祝福语 -->
                        <div class="mb-4">
                            <label for="message" class="block text-gray-700 font-medium mb-2">祝福语</label>
                            <textarea id="message" rows="4" placeholder="请输入你的祝福话语..." 
                                      class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors"></textarea>
                            <button id="ai-generate-btn" class="mt-2 bg-secondary hover:bg-secondary/90 text-white text-sm font-medium py-1 px-3 rounded-full transition-colors inline-flex items-center">
                                <i class="fa fa-magic mr-1"></i>
                                AI生成祝福语
                            </button>
                        </div>
                        
                        <!-- AI生成祝福语的选项 -->
                        <div id="ai-options" class="mb-4 hidden">
                            <div class="bg-blue-50 p-3 rounded-lg">
                                <h4 class="font-medium text-dark mb-2">AI生成选项</h4>
                                <div class="mb-2">
                                    <label class="block text-gray-700 text-sm mb-1">寿星年龄</label>
                                    <select id="age" class="w-full px-3 py-1 border border-gray-300 rounded-md text-sm">
                                        <option value="">请选择</option>
                                        <option value="child">儿童 (0-12岁)</option>
                                        <option value="teen">青少年 (13-19岁)</option>
                                        <option value="young">年轻人 (20-35岁)</option>
                                        <option value="adult">成年人 (36-50岁)</option>
                                        <option value="senior">长辈 (50岁以上)</option>
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <label class="block text-gray-700 text-sm mb-1">关系</label>
                                    <select id="relationship" class="w-full px-3 py-1 border border-gray-300 rounded-md text-sm">
                                        <option value="">请选择</option>
                                        <option value="family">家人</option>
                                        <option value="friend">朋友</option>
                                        <option value="lover">爱人</option>
                                        <option value="colleague">同事</option>
                                        <option value="teacher">老师/长辈</option>
                                    </select>
                                </div>
                                <div class="mb-2">
                                    <label class="block text-gray-700 text-sm mb-1">风格</label>
                                    <select id="style" class="w-full px-3 py-1 border border-gray-300 rounded-md text-sm">
                                        <option value="">请选择</option>
                                        <option value="warm">温馨感人</option>
                                        <option value="funny">幽默搞笑</option>
                                        <option value="romantic">浪漫深情</option>
                                        <option value="inspirational">励志鼓励</option>
                                        <option value="simple">简单朴实</option>
                                    </select>
                                </div>
                                <button id="generate-message-btn" class="w-full bg-secondary hover:bg-secondary/90 text-white text-sm font-medium py-2 rounded-md transition-colors mt-2">
                                    生成祝福语
                                </button>
                            </div>
                        </div>
                        
                        <!-- 上传照片 -->
                        <div class="mb-4">
                            <label class="block text-gray-700 font-medium mb-2">上传照片</label>
                            <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 text-center cursor-pointer hover:border-primary transition-colors" id="photo-upload-area">
                                <i class="fa fa-cloud-upload text-3xl text-gray-400 mb-2"></i>
                                <p class="text-gray-500 text-sm">点击或拖拽照片到这里上传</p>
                                <p class="text-gray-400 text-xs mt-1">支持 JPG、PNG 格式，最大 5MB</p>
                                <input type="file" id="photo-upload" class="hidden" accept="image/*">
                            </div>
                        </div>
                        
                        <!-- 背景音乐 -->
                        <div class="mb-4">
                            <label class="block text-gray-700 font-medium mb-2">背景音乐</label>
                            <select id="music" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors">
                                <option value="">请选择音乐</option>
                                <option value="happy">生日快乐歌 (经典版)</option>
                                <option value="joyful">欢乐生日歌 (轻快版)</option>
                                <option value="romantic">浪漫生日歌 (抒情版)</option>
                                <option value="none">无背景音乐</option>
                            </select>
                        </div>
                        
                        <button id="preview-btn" class="w-full bg-primary hover:bg-primary/90 text-white font-medium py-3 px-6 rounded-lg shadow-md hover:shadow-lg transition-all transform hover:-translate-y-1 mt-4">
                            预览效果
                        </button>
                    </div>
                    
                    <!-- 右侧：预览 -->
                    <div>
                        <h3 class="text-xl font-bold mb-6 text-dark border-b pb-2">实时预览</h3>
                        <div class="relative">
                            <!-- 模板预览区域 -->
                            <div id="template-preview" class="w-full h-96 bg-gray-100 rounded-lg overflow-hidden flex items-center justify-center">
                                <div class="text-center">
                                    <i class="fa fa-image text-4xl text-gray-400 mb-2"></i>
                                    <p class="text-gray-500">请先选择一个模板</p>
                                </div>
                            </div>
                            
                            <!-- 预览中的元素 -->
                            <div id="preview-name" class="hidden absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-center w-full px-4">
                                <h2 class="text-4xl font-bold text-white text-shadow-lg">亲爱的 [姓名]</h2>
                                <p class="text-xl text-white text-shadow mt-4">生日快乐！</p>
                            </div>
                            
                            <div id="preview-message" class="hidden absolute bottom-8 left-1/2 transform -translate-x-1/2 text-center w-full px-4">
                                <p class="text-white text-shadow-lg max-w-xs mx-auto"></p>
                            </div>
                            
                            <div id="preview-photo" class="hidden absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-32 h-32 rounded-full overflow-hidden border-4 border-white shadow-lg">
                                <!-- 照片将在这里显示 -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 分享区域 -->
    <section id="share" class="py-16 bg-white">
        <div class="container mx-auto px-4">
            <div class="text-center mb-12">
                <h2 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-dark mb-4">分享祝福</h2>
                <p class="text-gray-600 max-w-2xl mx-auto">
                    生成你的生日祝福页面，分享给寿星，给他/她一个惊喜！
                </p>
            </div>
            
            <div class="max-w-3xl mx-auto bg-gradient-to-br from-primary/5 to-secondary/5 rounded-xl shadow-lg p-8">
                <div class="text-center mb-8">
                    <div class="inline-block p-3 bg-primary/10 rounded-full mb-4">
                        <i class="fa fa-share-alt text-3xl text-primary"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-dark mb-2">准备好分享你的祝福了吗？</h3>
                    <p class="text-gray-600">
