                    <!-- 装饰气球 -->
                    <div class="absolute -top-10 -left-10 w-20 h-20 rounded-full bg-blue-400 balloon opacity-70"></div>
                    <div class="absolute top-20 -right-5 w-16 h-16 rounded-full bg-pink-400 balloon opacity-70"></div>
                    <div class="absolute bottom-10 -left-5 w-18 h-18 rounded-full bg-yellow-400 balloon opacity-70"></div>
                    <div class="absolute -bottom-5 right-20 w-14 h-14 rounded-full bg-green-400 balloon opacity-70"></div>
                </div>
            </div>
        </div>
        <!-- 背景装饰 -->
