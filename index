<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>生日祝福生成器 - 创建个性化生日祝福网页</title>
    <!-- Tailwind CSS v3 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <!-- 统一的 Tailwind 配置 -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#FF6B6B',
                        secondary: '#4ECDC4',
                        accent: '#FFE66D',
                        dark: '#1A535C',
                        light: '#F7FFF7'
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        display: ['Montserrat', 'sans-serif'],
                        cursive: ['Dancing Script', 'cursive']
                    },
                    animation: {
                        'float': 'float 3s ease-in-out infinite',
                        'bounce-slow': 'bounce 3s infinite',
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'confetti': 'confetti 3s ease-in-out forwards'
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' }
                        },
                        confetti: {
                            '0%': { transform: 'translateY(-100vh) rotate(0deg)' },
                            '100%': { transform: 'translateY(100vh) rotate(360deg)' }
                        }
                    }
                }
            }
        }
    </script>
    <style type="text/tailwindcss">
        @layer utilities {
            .text-shadow {
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
            }
            .text-shadow-lg {
                text-shadow: 4px 4px 8px rgba(0, 0, 0, 0.5);
            }
            .bg-blur {
                backdrop-filter: blur(8px);
            }
            .glass {
                background: rgba(255, 255, 255, 0.25);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255, 255, 255, 0.18);
            }
            .template-card {
                transition: all 0.3s ease;
            }
            .template-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            }
            .confetti-piece {
                position: absolute;
                width: 10px;
                height: 10px;
                opacity: 0;
                animation: confetti-fall 3s ease-in-out forwards;
            }
            @keyframes confetti-fall {
                0% {
                    transform: translateY(-100vh) rotate(0deg);
                    opacity: 1;
                }
                100% {
                    transform: translateY(100vh) rotate(360deg);
                    opacity: 0;
                }
            }
            .candle-flame {
                animation: flicker 1s infinite alternate;
            }
            @keyframes flicker {
                0% {
                    transform: scale(1);
                    opacity: 0.8;
                }
                100% {
                    transform: scale(1.1);
                    opacity: 1;
                }
            }
            .balloon {
                animation: float 3s ease-in-out infinite;
            }
            .balloon:nth-child(2) {
                animation-delay: 0.5s;
            }
            .balloon:nth-child(3) {
                animation-delay: 1s;
            }
            .balloon:nth-child(4) {
                animation-delay: 1.5s;
            }
        }
    </style>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@500;600;700;800&family=Dancing+Script:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-pink-50 to-blue-50 min-h-screen">
    <!-- 导航栏 -->
    <nav class="bg-white shadow-md sticky top-0 z-50">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <i class="fa fa-birthday-cake text-primary text-2xl"></i>
                <h1 class="text-xl font-bold text-dark">生日祝福生成器</h1>
            </div>
            <div class="hidden md:flex space-x-6">
                <a href="#templates" class="text-gray-600 hover:text-primary transition-colors">模板</a>
                <a href="#customize" class="text-gray-600 hover:text-primary transition-colors">定制</a>
                <a href="#preview" class="text-gray-600 hover:text-primary transition-colors">预览</a>
                <a href="#share" class="text-gray-600 hover:text-primary transition-colors">分享</a>
            </div>
            <button id="mobile-menu-button" class="md:hidden text-gray-600 focus:outline-none">
                <i class="fa fa-bars text-xl"></i>
            </button>
        </div>
        <!-- 移动端菜单 -->
        <div id="mobile-menu" class="md:hidden hidden bg-white shadow-lg absolute w-full">
            <div class="container mx-auto px-4 py-2 flex flex-col space-y-3">
                <a href="#templates" class="text-gray-600 hover:text-primary transition-colors py-2">模板</a>
                <a href="#customize" class="text-gray-600 hover:text-primary transition-colors py-2">定制</a>
                <a href="#preview" class="text-gray-600 hover:text-primary transition-colors py-2">预览</a>
                <a href="#share" class="text-gray-600 hover:text-primary transition-colors py-2">分享</a>
            </div>
        </div>
    </nav>

    <!-- 英雄区域 -->
    <header class="relative overflow-hidden py-16 md:py-24">
        <div class="container mx-auto px-4">
            <div class="flex flex-col md:flex-row items-center justify-between">
                <div class="md:w-1/2 mb-10 md:mb-0">
                    <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-bold text-dark leading-tight mb-4">
                        创建<span class="text-primary">个性化</span>生日祝福
                    </h1>
                    <p class="text-gray-600 text-lg mb-8">
                        选择模板，添加照片和文字，生成独特的生日祝福页面，给寿星一个惊喜！
                    </p>
                    <a href="#templates" class="bg-primary hover:bg-primary/90 text-white font-medium py-3 px-6 rounded-full shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1 inline-flex items-center">
                        <i class="fa fa-magic mr-2"></i>
