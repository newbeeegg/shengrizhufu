            // 下载二维码按钮
            const downloadQrBtn = document.getElementById('download-qr-btn');
            
            downloadQrBtn.addEventListener('click', function() {
                const qrcode = document.getElementById('qrcode');
                const canvas = qrcode.querySelector('canvas');
                
                if (canvas) {
                    // 创建下载链接
                    const link = document.createElement('a');
                    link.download = `birthday-wish-${nameInput.value.trim()}.png`;
                    link.href = canvas.toDataURL('image/png');
                    link.click();
                }
            });
            
            // 背景音乐选择
            const musicSelect = document.getElementById('music');
            
            musicSelect.addEventListener('change', function() {
                // 停止当前播放的音乐
                if (audio) {
                    audio.pause();
                    audio = null;
                }
                
                // 如果选择了音乐，播放
                if (this.value && this.value !== 'none') {
                    playBackgroundMusic(this.value);
                }
            });
        });
        
        // 更新模板预览
        function updateTemplatePreview(templateType) {
            const templatePreview = document.getElementById('template-preview');
            let templateImage = '';
            
            switch(templateType) {
                case 'luxury':
                    templateImage = 'https://p3-flow-imagex-sign.byteimg.com/tos-cn-i-a9rns2rl98/rc/pc/super_tool/96cafd26b1f54379b69cf8ba6242dcc8~tplv-a9rns2rl98-image.image?lk3s=8e244e95&rcl=202603182152091F69194F6EE27C8D2F2D&rrcfp=f06b921b&x-expires=1776433965&x-signature=9iewx3chk1rChyI2U6uqIixbnuk%3D';
