        // 更新姓名预览
        function updateNamePreview() {
            const nameInput = document.getElementById('name');
            const previewName = document.getElementById('preview-name');
            const nameElement = previewName.querySelector('h2');
            
            if (nameInput.value.trim()) {
                nameElement.textContent = `亲爱的 ${nameInput.value.trim()}`;
            } else {
                nameElement.textContent = '亲爱的 [姓名]';
            }
        }
        
        // 更新消息预览
        function updateMessagePreview() {
            const messageInput = document.getElementById('message');
            const previewMessage = document.getElementById('preview-message');
            const messageElement = previewMessage.querySelector('p');
            
            if (messageInput.value.trim()) {
                messageElement.textContent = messageInput.value.trim();
            } else {
                messageElement.textContent = '愿你的生日充满欢乐和惊喜，祝你生日快乐！';
            }
        }
        
        // 处理照片上传
        function handlePhotoUpload(file) {
            // 检查文件类型
            if (!file.type.match('image.*')) {
                alert('请上传图片文件');
                return;
            }
            
            // 检查文件大小
            if (file.size > 5 * 1024 * 1024) {
                alert('图片大小不能超过5MB');
                return;
            }
            
            const reader = new FileReader();
            
            reader.onload = function(e) {
                uploadedPhoto = e.target.result;
                
                // 更新预览
                const previewPhoto = document.getElementById('preview-photo');
                previewPhoto.style.backgroundImage = `url(${uploadedPhoto})`;
                previewPhoto.style.backgroundSize = 'cover';
                previewPhoto.style.backgroundPosition = 'center';
                previewPhoto.classList.remove('hidden');
                
                // 隐藏姓名预览
                document.getElementById('preview-name').classList.add('hidden');
            };
            
            reader.readAsDataURL(file);
        }
        
