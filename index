        // 播放生日歌
        function playBirthdaySong() {
            // 停止当前播放的音乐
            if (audio) {
                audio.pause();
                audio = null;
            }
            
            // 创建新的音频对象
            audio = new Audio('https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3');
            audio.loop = false;
            audio.play();
        }
        
        // 播放背景音乐
        function playBackgroundMusic(type) {
            // 停止当前播放的音乐
            if (audio) {
                audio.pause();
                audio = null;
            }
            
            // 根据类型选择音乐
            let musicUrl = '';
            
            switch(type) {
                case 'happy':
                    musicUrl = 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3';
                    break;
                case 'joyful':
                    musicUrl = 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3';
                    break;
                case 'romantic':
                    musicUrl = 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3';
                    break;
                default:
                    return;
            }
            
            // 创建新的音频对象
            audio = new Audio(musicUrl);
            audio.loop = true;
            audio.volume = 0.5;
            audio.play();
        }
        
        // 创建彩带效果
        function createConfetti() {
            const container = document.createElement('div');
            container.style.position = 'fixed';
            container.style.top = '0';
            container.style.left = '0';
            container.style.width = '100%';
            container.style.height = '100%';
            container.style.pointerEvents = 'none';
            container.style.zIndex = '9999';
            document.body.appendChild(container);
            
            // 创建100个彩带
            for (let i = 0; i < 100; i++) {
                const confetti = document.createElement('div');
                confetti.className = 'confetti-piece';
                
                // 随机颜色
                const colors = ['#FF6B6B', '#4ECDC4', '#FFE66D', '#1A535C', '#F7FFF7', '#FF9F1C', '#E71D36', '#011627'];
                confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                
                // 随机大小
                const size = Math.random() * 10 + 5;
                confetti.style.width = `${size}px`;
                confetti.style.height = `${size}px`;
                
                // 随机位置
                confetti.style.left = `${Math.random() * 100}%`;
                
                // 随机旋转
                confetti.style.transform = `rotate(${Math.random() * 360}deg)`;
                
                // 随机动画延迟
                confetti.style.animationDelay = `${Math.random() * 3}s`;
                
                // 随机动画持续时间
                confetti.style.animationDuration = `${Math.random() * 3 + 2}s`;
                
                container.appendChild(confetti);
            }
            
            // 3秒后移除容器
            setTimeout(() => {
                document.body.removeChild(container);
            }, 5000);
        }
        
        // 生成二维码
        function generateQRCode(url) {
            const qrcode = document.getElementById('qrcode');
            
            // 清空之前的内容
            while (qrcode.firstChild) {
                qrcode.removeChild(qrcode.firstChild);
            }
            
            // 创建二维码图片
            const img = document.createElement('img');
            img.src = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(url)}`;
            img.alt = '生日祝福二维码';
            img.className = 'w-32 h-32';
            
            qrcode.appendChild(img);
        }
        
        // 分享到社交媒体
        function shareToSocialMedia(platform, url) {
            let shareUrl = '';
            const text = `快来查看我为你准备的生日祝福！`;
            
            switch(platform) {
                case 'facebook':
                    shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
                    break;
                case 'twitter':
                    shareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;
                    break;
                case 'instagram':
                    // Instagram不支持直接分享链接，需要提示用户
                    alert('请下载二维码，然后在Instagram上分享！');
                    return;
                case 'whatsapp':
                    shareUrl = `https://wa.me/?text=${encodeURIComponent(text + ' ' + url)}`;
                    break;
                case 'envelope':
                    shareUrl = `mailto:?subject=${encodeURIComponent('生日祝福')}&body=${encodeURIComponent(text + ' ' + url)}`;
                    break;
                default:
                    return;
            }
            
            // 打开分享链接
            window.open(shareUrl, '_blank');
        }
